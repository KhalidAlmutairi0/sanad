# SANAD production env. Copy to infra/.env on the VM and fill in. NEVER commit real values.
# Generate every secret fresh: openssl rand -hex 32

# --- Domains (DNS A records both point at the VM) -------------------------
DOMAIN=sanad.example.com
MINIO_DOMAIN=storage.sanad.example.com

# --- Postgres -------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sanad
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=__CHANGE_ME__
SANAD_MIGRATOR_USER=sanad_migrator
SANAD_MIGRATOR_PASSWORD=__CHANGE_ME__
SANAD_APP_USER=sanad_app
SANAD_APP_PASSWORD=__CHANGE_ME__

# --- Redis ----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO (browser reaches it via MINIO_DOMAIN over TLS through Caddy) ----
MINIO_ROOT_USER=sanad_minio
MINIO_ROOT_PASSWORD=__CHANGE_ME_min_8_chars__
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=storage.sanad.example.com
MINIO_USE_SSL=false
MINIO_PUBLIC_SECURE=true
MINIO_BUCKET_QUARANTINE=sanad-quarantine
MINIO_BUCKET_SANITIZED=sanad-sanitized

# --- Embedder -------------------------------------------------------------
EMBEDDER_URL=http://embedder:8081
EMBEDDER_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024

# --- LLM (stub for now; wire a real provider later) -----------------------
# selfhosted with no URL = deterministic offline stub (plumbing runs, no external model).
LLM_PROVIDER=selfhosted
LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=
SELFHOSTED_LLM_URL=
SELFHOSTED_LLM_MODEL=

# --- Auth -----------------------------------------------------------------
JWT_SECRET=__CHANGE_ME_openssl_rand_hex_32__
JWT_EXPIRE_HOURS=8
INTERNAL_SERVICE_TOKEN=__CHANGE_ME_openssl_rand_hex_32__

# --- App ------------------------------------------------------------------
APP_ENV=production
API_BASE_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=https://sanad.example.com
MAX_UPLOAD_MB=50
SANITIZER_TIMEOUT_SECONDS=60
