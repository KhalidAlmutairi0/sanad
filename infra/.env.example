# SANAD environment. Copy to infra/.env and fill in. NEVER commit real secrets.

# --- Postgres -------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sanad
# Superuser (bootstrap + role creation only; the app never uses this).
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change_me_superuser
# Migrator role: owns DDL (Alembic connects as this).
SANAD_MIGRATOR_USER=sanad_migrator
SANAD_MIGRATOR_PASSWORD=change_me_migrator
# App role: INSERT+SELECT only on append-only tables, CRUD elsewhere. The API/workers use this.
SANAD_APP_USER=sanad_app
SANAD_APP_PASSWORD=change_me_app

# --- Redis (arq queue) ----------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO (S3, server-side encryption) -----------------------------------
MINIO_ROOT_USER=sanad_minio
MINIO_ROOT_PASSWORD=change_me_minio_at_least_8_chars
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
# TLS on the browser-facing MinIO endpoint (true in production behind Caddy).
MINIO_PUBLIC_SECURE=false
MINIO_BUCKET_QUARANTINE=sanad-quarantine
MINIO_BUCKET_SANITIZED=sanad-sanitized

# --- Embedder (multilingual-e5-large, self-hosted) ------------------------
EMBEDDER_URL=http://embedder:8081
EMBEDDER_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024

# --- LLM (behind services/llm only; key lives ONLY in api/worker) ---------
# Provider: anthropic | selfhosted
LLM_PROVIDER=selfhosted
LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=
# Self-hosted OpenAI-compatible endpoint (air-gapped option). Used when LLM_PROVIDER=selfhosted.
SELFHOSTED_LLM_URL=
SELFHOSTED_LLM_MODEL=

# --- Auth -----------------------------------------------------------------
# 32+ byte random string. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_a_long_random_hex
JWT_EXPIRE_HOURS=8
# Service token for sandbox workers calling /internal/* endpoints.
INTERNAL_SERVICE_TOKEN=change_me_internal_service_token

# --- App ------------------------------------------------------------------
APP_ENV=local
API_BASE_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
MAX_UPLOAD_MB=50
SANITIZER_TIMEOUT_SECONDS=60
